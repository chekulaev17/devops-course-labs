[Unit]
Description=Catty Reminders Application
After=network.target

[Service]
User=chekulaev17
WorkingDirectory=/home/chekulaev17/catty-reminders-app
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8181
Restart=always
EnvironmentFile=/etc/default/catty
[Install]
WantedBy=multi-user.target
